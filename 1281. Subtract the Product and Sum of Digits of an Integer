//1281. Subtract the Product and Sum of Digits of an Integer

class Solution {
    public int subtractProductAndSum(int n) {
        return prod(n)-sum(n);
    }
    int sum(int n){
        if(n==0){
            return 0;
        }
        else{
            return (n%10)+sum(n/10);
        }
    }int prod(int n){
        if(n==0){
            return 1;
        }
        else{
            return (n%10)*prod(n/10);
        }
    }
}
