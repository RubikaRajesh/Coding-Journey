//9. Palindrome Number
class Solution {
    public boolean isPalindrome(int x) {
        if(x<0){
            return false;
        }
        int dig=(int)(Math.log10(x))+1;
        return x==helper(x,dig);
    }
    int helper(int n,int digits){
        if(n%10==n){
            return n;
        }
        return (n%10)*((int)Math.pow(10,digits-1))+helper(n/10,digits-1);
    }
}
